generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DishCategory {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  name        String
  description String?
  dishes      Dish[]

  @@map("dish_categories")
}

model IngredientCategoryL1 {
  id       Int                    @id @default(autoincrement())
  code     String                 @unique
  name     String
  children IngredientCategoryL2[]

  @@map("ingredient_categories_l1")
}

model IngredientCategoryL2 {
  id          Int                  @id @default(autoincrement())
  code        String               @unique
  name        String
  parentCode  String               @map("parent_code")
  description String?
  parent      IngredientCategoryL1 @relation(fields: [parentCode], references: [code])

  @@map("ingredient_categories_l2")
}

model Unit {
  id       Int    @id @default(autoincrement())
  name     String @unique
  category String

  @@map("units")
}

model Supplier {
  id       Int               @id @default(autoincrement())
  name     String
  contact  String?
  phone    String?
  remark   String?
  receipts PurchaseReceipt[]

  @@map("suppliers")
}

model Ingredient {
  id           Int                   @id @default(autoincrement())
  code         String                @unique
  name         String
  alias        String?
  l2Code       String                @map("l2_code")
  unit         String                @map("unit")
  priceUnit    String                @map("price_unit")
  purchaseSpec String?               @map("purchase_spec")
  season       String                @default("四季") @map("season")
  storage      String                @map("storage")
  inventory    Inventory?
  ledger       InventoryLedger[]
  netIngredients NetIngredient[]
  receiptItems   PurchaseReceiptItem[]
  @@map("ingredients")
}

model NetIngredient {
  id                 Int             @id @default(autoincrement())
  code               String          @unique
  name               String
  sourceIngredientId Int             @map("source_ingredient_id")
  spec               String?
  yieldRate          Decimal         @map("yield_rate") @db.Decimal(5, 2)
  unitPrice          Decimal         @map("unit_price") @db.Decimal(10, 2)
  unit               String          @default("500g") @map("unit")
  l2Code             String          @map("l2_code")
  storage            String          @map("storage")
  dishNetDetails     DishNetDetail[]
  sourceIngredient   Ingredient      @relation(fields: [sourceIngredientId], references: [id])

  @@map("net_ingredients")
}

model MinorIngredient {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  name      String
  spec      String? @map("spec")
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  unit      String  @default("10g") @map("unit")
  origin    String? @map("origin")
  storage   String  @map("storage")
  @@map("minor_ingredients")
}

model SeasoningIngredient {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  name          String
  brand         String
  productSpec   String? @map("product_spec")
  productUnit   String? @map("product_unit")
  retailPrice   Decimal? @map("retail_price") @db.Decimal(10, 2)
  purchasePrice Decimal @map("purchase_price") @db.Decimal(10, 2)
  purchaseUnit  String  @map("purchase_unit")
  storage       String  @map("storage")

  @@map("seasoning_ingredients")
}

model SauceIngredient {
  id               Int               @id @default(autoincrement())
  code             String            @unique
  name             String
  brand            String
  recipe           String?
  storage          String            @map("storage")
  unitPrice        Decimal           @map("unit_price") @db.Decimal(10, 2)
  unit             String            @map("unit")
  dishSauceDetails DishSauceDetail[]

  @@map("sauce_ingredients")
}

model Dish {
  id               Int                   @id @default(autoincrement())
  code             String                @unique
  name             String
  intro            String?
  categoryId       Int                   @map("category_id")
  cuisine          String?
  technique        String?
  taste            String?
  portion          String                @default("正餐份量")
  season           String                @default("四季")
  meatType         String?               @map("meat_type")
  cost             Decimal?              @db.Decimal(10, 2)
  status           String                @default("draft") @map("status") // draft / pending / published
  operator         String?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  netDetails       DishNetDetail[]
  processes        DishProcess[]
  sauceDetails     DishSauceDetail[]
  seasoningDetails DishSeasoningDetail[]
  category         DishCategory          @relation(fields: [categoryId], references: [id])
  scheduleItems    ScheduleItem[]

  @@map("dishes")
}

model DishNetDetail {
  id            Int           @id @default(autoincrement())
  dishId        Int           @map("dish_id")
  role          String        // main(主料) / support(辅料)
  netIngId      Int           @map("net_ing_id")
  amountG       Decimal       @map("amount_g") @db.Decimal(10, 2)
  spec          String?
  cost          Decimal?      @db.Decimal(10, 2)
  dish          Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)
  netIngredient NetIngredient @relation(fields: [netIngId], references: [id])

  @@map("dish_net_details")
}

model DishSeasoningDetail {
  id       Int      @id @default(autoincrement())
  dishId   Int      @map("dish_id")
  type     String   // minor(小料) / seasoning(调料)
  sourceId Int      @map("source_id")
  amountG  Decimal  @map("amount_g") @db.Decimal(10, 2)
  brand    String?
  cost     Decimal? @db.Decimal(10, 2)
  dish     Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("dish_seasoning_details")
}

model DishSauceDetail {
  id      Int             @id @default(autoincrement())
  dishId  Int             @map("dish_id")
  sauceId Int             @map("sauce_id")
  amountG Decimal         @map("amount_g") @db.Decimal(10, 2)
  brand   String?
  cost    Decimal?        @db.Decimal(10, 2)
  dish    Dish            @relation(fields: [dishId], references: [id], onDelete: Cascade)
  sauce   SauceIngredient @relation(fields: [sauceId], references: [id])

  @@map("dish_sauce_details")
}


model DishProcess {
  id          Int     @id @default(autoincrement())
  dishId      Int     @map("dish_id")
  stage       String
  stepNo      Int     @map("step_no")
  object      String
  action      String
  description String?
  tool        String?
  standard    String?
  dish        Dish    @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("dish_processes")
}

model Schedule {
  id            Int            @id @default(autoincrement())
  title         String
  scheduleDate  DateTime       @map("schedule_date") @db.Date
  scope         String         @default("全部食堂")
  status        String         @default("待生效")
  operator      String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  cuttingOrders CuttingOrder[]
  purchasePlans PurchasePlan[]
  items         ScheduleItem[]

  @@map("schedules")
}

model ScheduleItem {
  id         Int      @id @default(autoincrement())
  scheduleId Int      @map("schedule_id")
  dishId     Int      @map("dish_id")
  quantity   Int
  dish       Dish     @relation(fields: [dishId], references: [id])
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("schedule_items")
}

model PurchasePlan {
  id                Int        @id @default(autoincrement())
  scheduleId        Int        @map("schedule_id")
  sourceType        String     @map("source_type") // ingredient / minor / seasoning / sauce
  sourceId          Int        @map("source_id")
  itemName          String     @map("item_name")
  l2Code            String?    @map("l2_code")
  grossNeed         Decimal    @map("gross_need") @db.Decimal(10, 2)
  stockDeducted     Decimal    @map("stock_deducted") @db.Decimal(10, 2)
  suggestedPurchase Decimal    @map("suggested_purchase") @db.Decimal(10, 2)
  unit              String
  purchaseSpec      String?    @map("purchase_spec")
  priceUnit         String?    @map("price_unit")
  actualPurchase    Decimal?   @map("actual_purchase") @db.Decimal(10, 2)
  actualAmount      Decimal?   @map("actual_amount") @db.Decimal(10, 2)
  status            String     @default("pending")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  schedule          Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("purchase_plans")
}

model CuttingOrder {
  id            Int           @id @default(autoincrement())
  scheduleId    Int           @map("schedule_id")
  sourceType    String        @map("source_type") // net / minor
  sourceId      Int           @map("source_id")
  itemName      String        @map("item_name")
  l1Code        String?       @map("l1_code")
  l2Code        String?       @map("l2_code")
  spec          String?
  requiredQty   Decimal       @map("required_qty") @db.Decimal(10, 2)
  unit          String
  actualQty     Decimal?      @map("actual_qty") @db.Decimal(10, 2)
  status        String        @default("pending")
  schedule      Schedule      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@map("cutting_orders")
}

model PurchaseReceipt {
  id          Int                   @id @default(autoincrement())
  receiptDate DateTime              @map("receipt_date") @db.Date
  supplierId  Int?                  @map("supplier_id")
  summary     String?               // 采购摘要
  totalAmount Decimal               @map("total_amount") @db.Decimal(10, 2)
  operator    String?
  imageUrl    String?               @map("image_url")
  status      String                @default("completed") // completed 不可删除
  createdAt   DateTime              @default(now()) @map("created_at")
  items       PurchaseReceiptItem[]
  supplier    Supplier?             @relation(fields: [supplierId], references: [id])

  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id           Int             @id @default(autoincrement())
  receiptId    Int             @map("receipt_id")
  ingredientId Int?            @map("ingredient_id")
  itemName     String          @map("item_name")
  spec         String?
  qty          Decimal         @db.Decimal(10, 2)
  priceUnit    String          @map("price_unit")
  unitPrice    Decimal         @map("unit_price") @db.Decimal(10, 2)
  amount       Decimal         @db.Decimal(10, 2)
  stockUnit    String          @map("stock_unit")
  stockInQty   Decimal         @map("stock_in_qty") @db.Decimal(10, 2)
  storage      String
  ingredient   Ingredient?     @relation(fields: [ingredientId], references: [id])
  receipt      PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@map("purchase_receipt_items")
}

model Inventory {
  id           Int        @id @default(autoincrement())
  ingredientId Int        @unique @map("ingredient_id")
  currentQty   Decimal    @map("current_qty") @db.Decimal(10, 2)
  unit         String
  updatedAt    DateTime   @updatedAt @map("updated_at")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("inventory")
}

model InventoryLedger {
  id                Int        @id @default(autoincrement())
  ingredientId      Int        @map("ingredient_id")
  changeTime        DateTime   @default(now()) @map("change_time")
  changeType        String     @map("change_type") // 入库 / 出库
  changeQty         Decimal    @map("change_qty") @db.Decimal(10, 2)
  unit              String
  balance           Decimal    @db.Decimal(10, 2)
  source            String
  settlementStatus  String     @default("待结算") @map("settlement_status")
  operator          String?
  createdAt         DateTime   @default(now()) @map("created_at")
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("inventory_ledger")
}

model PurchaseReimbursement {
  id          Int      @id @default(autoincrement())
  title       String   // 报销主题
  summary     String?  // 摘要
  receiptIds  Int[]    @map("receipt_ids")
  totalAmount Decimal  @map("total_amount") @db.Decimal(10, 2)
  status      String   @default("pending") // pending / settled
  operator    String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("purchase_reimbursements")
}

model User {
  id        Int            @id @default(autoincrement())
  username  String         @unique
  password  String
  name      String?
  role      String?        @map("role")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  logs      OperationLog[]

  @@map("users")
}

model OperationLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity      String   // 操作的实体名称，如 Ingredient, DishCategory
  entityId    Int?     @map("entity_id")
  description String?
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id])

  @@map("operation_logs")
}
